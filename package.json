{
  "name": "msa-website",
  "version": "1.0.0",
  "type": "module",
  "description": "Rutgers MSA Website",
  "main": "index.html",
  "scripts": {
    "dev": "node dev-server.js",
    "dev:restart": "lsof -ti :3002 | xargs kill -9 2>/dev/null; sleep 1; node dev-server.js",
    "dev:vercel": "vercel dev --yes",
    "build": "echo 'No build step required for static site'",
    "deploy": "vercel --prod",
    "upload-art-gala": "node upload-art-gala-to-blob.js"
  },
  "dependencies": {
    "@vercel/blob": "^0.19.0"
  },
  "devDependencies": {
    "vercel": "^32.0.0"
  },
  "keywords": ["msa", "rutgers", "website", "vercel"],
  "author": "Shaheer Saud",
  "license": "MIT"
}

